{
  "name": "ruragriconnect-server",
  "version": "1.0.0",
  "description": "RuralAgriConnect API — Node.js + Express + SQLite",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:seed": "ts-node src/db/seed.ts",
    "audit": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@google/generative-ai": "^0.24.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.41",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^9.0.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^12.7.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.9",
    "openai": "^6.39.0",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "resend": "^6.12.4",
    "sql.js": "^1.12.0",
    "typescript": "^5.4.3",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "ts-node-dev": "^2.0.0",
    "vitest": "^2.1.0"
  }
}
