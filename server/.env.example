# ── Server ──────────────────────────────────────────────────
PORT=3001

# ── Database ─────────────────────────────────────────────────
# Path to the SQLite database file (relative to server/)
DB_PATH=./data/ruragriconnect.db

# ── Authentication ───────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret

# ── Email (for forgot password / email verification) ─────────
# Use a Gmail account with an App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── App URL (used in password reset emails) ──────────────────
APP_URL=https://ruralagriconnect-15c7c.web.app

# ── AI (Google Gemini) ───────────────────────────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Weather (OpenWeatherMap) ─────────────────────────────────
# Get a free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ── Environment ──────────────────────────────────────────────
NODE_ENV=development

# ── CORS (comma-separated extra origins, optional) ───────────
# ALLOWED_ORIGINS=https://your-custom-domain.com
