# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001

# ── Database ─────────────────────────────────────────────────────────────────
# Path to the SQLite database file (relative to server/)
DB_PATH=./data/ruragriconnect.db

# ── Authentication ────────────────────────────────────────────────────────────
# SECURITY: Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Must be at least 32 characters. Never use the placeholder value.
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_chars

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get a free API key at: https://resend.com
# SECURITY: Never commit real API keys to source control
RESEND_API_KEY=re_your_resend_api_key_here

# ── App URL (used in password reset and verification emails) ──────────────────
# Local dev: http://localhost:5173
# Production: https://ruralagriconnect-15c7c.web.app
APP_URL=http://localhost:5173

# ── AI (Google Gemini) — image vision (primary) ──────────────────────────────
# Dedicated key for crop image scanning. Uses its own free-tier quota (1500 req/day)
# so text chat (GEMINI_API_KEY) cannot exhaust it. Get at: https://aistudio.google.com/app/apikey
VISION_API_KEY=your_vision_api_key_here

# ── AI (Google Gemini) — text chat + vision fallback ─────────────────────────
# Used for AI text chat and as fallback if VISION_API_KEY quota is exhausted.
# SECURITY: Restrict this key to the Generative Language API in Google Cloud Console
GEMINI_API_KEY=your_gemini_api_key_here

# ── AI (HuggingFace) — third-level vision fallback ───────────────────────────
# Used for image scanning when BOTH Gemini keys are quota-exhausted.
# Free tier: generate a fine-grained token at huggingface.co/settings/tokens
# Model used: Salesforce/blip-image-captioning-large
HF_API_KEY=your_hf_api_key_here


# ── Weather (OpenWeatherMap) ──────────────────────────────────────────────────
# Get a free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ── Environment ───────────────────────────────────────────────────────────────
# SECURITY: Set to 'production' in production — enables stack trace suppression
# and production-safe error responses
NODE_ENV=development

# ── CORS (comma-separated extra origins, optional) ────────────────────────────
# ALLOWED_ORIGINS=https://your-custom-domain.com

# ── Field-Level Encryption (A04) ─────────────────────────────────────────────
# SECURITY: AES-256-GCM key for encrypting phone numbers and regions in SQLite.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes = 256 bits). Never reuse. Never commit.
# Without this key, PII fields remain as legacy plaintext (migration-safe).
FIELD_ENCRYPTION_KEY=change_this_to_64_hex_chars_generated_with_crypto_randomBytes_32

# ── SIEM / Security Alerting Webhook (A09) ────────────────────────────────────
# Optional: POST security and audit events to this URL in real time.
# Compatible with Slack incoming webhooks, PagerDuty, MS Teams, Splunk HEC,
# Datadog Logs API, Google Cloud Logging sinks, etc.
# Leave empty to disable (logs still written to stdout for container capture).
# SECURITY_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
# SECURITY_WEBHOOK_TOKEN=optional_bearer_token_for_authenticated_siem_endpoints

# ── SECRETS MANAGEMENT RECOMMENDATIONS ───────────────────────────────────────
# Production: Use Railway environment variables (never commit .env to git)
# Local dev: Use .env file (already in .gitignore)
# Rotation: Rotate JWT_SECRET and API keys every 90 days
# Monitoring: Set up alerts in Google Cloud Console for unusual Gemini API usage
# Principle of least privilege: Restrict each API key to only the APIs it needs
