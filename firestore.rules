rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────────────
    function isAuth()  { return request.auth != null; }
    function isMe(uid) { return request.auth.uid == uid; }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function owns(field) {
      return isAuth() && resource.data[field] == request.auth.uid;
    }

    // ── users ─────────────────────────────────────────────────────────────────
    //
    // SECURITY FIX — A01: Restrict user profile reads to owner or admin only.
    //
    // Vulnerability: The previous rule allowed ANY authenticated user to read
    // ALL user profiles, exposing phone numbers and regions to all logged-in users.
    //
    // Attack scenario: A malicious farmer logs in and reads all user profiles,
    // harvesting phone numbers and regions for social engineering or spam.
    //
    // Risk severity: HIGH (PII exposure — phone numbers, regions)
    //
    // Remediation: Profiles are now readable only by the profile owner or an admin.
    // Community features that need author names should store the display name
    // denormalized in the post/reply document (already done in SQLite layer).
    //
    // Why secure: Principle of least privilege — users only see their own data.
    // Admins retain full read access for moderation and support purposes.
    match /users/{userId} {
      // SECURITY FIX — A01: Only owner or admin can read a profile
      allow read:   if isAuth() && (isMe(userId) || isAdmin());
      // Role must be 'farmer' on create — admins can only be assigned via admin panel
      allow create: if isAuth() && isMe(userId) && request.resource.data.role == 'farmer';
      // Users may update their own profile but cannot escalate their own role
      allow update: if isAuth() && (
        (isMe(userId) && request.resource.data.role == resource.data.role) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── advisories — read by all authenticated, write by admin ───────────────
    match /advisories/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── notifications — read own + broadcast ─────────────────────────────────
    match /notifications/{id} {
      allow read:   if isAuth() &&
        (resource.data.user_id == request.auth.uid ||
         resource.data.user_id == 'broadcast');
      // Users can create notifications for themselves; disease_alert type allowed
      allow create: if isAdmin() ||
        (isAuth() && request.resource.data.user_id == request.auth.uid) ||
        (isAuth() && request.resource.data.type == 'community');
      // Users can mark their own or broadcast notifications as read (read field only)
      allow update: if isAuth() && (
        resource.data.user_id == request.auth.uid ||
        (resource.data.user_id == 'broadcast' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']))
      );
      allow delete: if isAdmin();
    }

    // ── community posts + replies ─────────────────────────────────────────────
    //
    // SECURITY FIX — A01: Ownership check on updates.
    // The previous rule allowed any authenticated user to update any post.
    // Now only the post owner or an admin can update post content.
    // Counter fields (reply_count, likes) can still be incremented by any auth user.
    match /community_posts/{postId} {
      allow read:   if isAuth();
      allow create: if isAuth() && request.resource.data.user_id == request.auth.uid;
      // SECURITY FIX — A01: Owner/admin can edit content; any auth user can
      // increment reply_count or likes (counter-only updates)
      allow update: if isAuth() && (
        owns('user_id') || isAdmin() ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reply_count', 'likes'])
      );
      allow delete: if isAuth() && (owns('user_id') || isAdmin());

      match /replies/{replyId} {
        allow read:   if isAuth();
        // Block muted users from replying in channels
        allow create: if isAuth() &&
          request.resource.data.user_id == request.auth.uid &&
          !(request.auth.uid in get(/databases/$(database)/documents/community_posts/$(postId)).data.get('muted_users', []));
        allow update: if isAuth() && (owns('user_id') || isAdmin());
        allow delete: if isAuth() && (owns('user_id') || isAdmin());
      }
    }

    // ── yield reports — own data; admin sees all ──────────────────────────────
    match /yield_reports/{id} {
      allow read:   if isAuth() && (owns('farmer_id') || isAdmin());
      allow create: if isAuth() && request.resource.data.farmer_id == request.auth.uid;
      allow update: if isAuth() && (owns('farmer_id') || isAdmin());
      allow delete: if isAdmin();
    }

    // ── farm fields — own data; admin sees all ────────────────────────────────
    match /farm_fields/{id} {
      allow read:   if isAuth() && (owns('farmer_id') || isAdmin());
      allow create: if isAuth() && request.resource.data.farmer_id == request.auth.uid;
      allow update: if isAuth() && (owns('farmer_id') || isAdmin());
      allow delete: if isAuth() && (owns('farmer_id') || isAdmin());
    }

    // ── subsidy requests — own data; admin manages ────────────────────────────
    match /subsidy_requests/{id} {
      allow read:   if isAuth() && (owns('farmer_id') || isAdmin());
      allow create: if isAuth() && request.resource.data.farmer_id == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── pest outbreaks — all auth can read; admin writes ─────────────────────
    match /pest_outbreaks/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── crop scans — own data ─────────────────────────────────────────────────
    match /crop_scans/{id} {
      allow read:   if isAuth() && (owns('user_id') || isAdmin());
      allow create: if isAuth() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── weather data — all auth can read; admin writes ────────────────────────
    match /weather_data/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── crop calendar — all auth can read; admin writes ───────────────────────
    match /crop_calendar/{id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }

    // ── activity logs — immutable; admin reads ────────────────────────────────
    match /activity_logs/{id} {
      allow read:           if isAdmin();
      allow create:         if isAuth();
      allow update, delete: if false;
    }

    // ── security logs — immutable audit trail; admin reads only ──────────────
    // SECURITY FIX — A09: Allow unauthenticated writes for security event logging.
    // This enables logging during login/register when no token exists yet.
    // The endpoint validates the request body to prevent log injection.
    match /security_logs/{id} {
      allow read:           if isAdmin();
      allow create:         if true;  // Allow both authenticated and unauthenticated writes
      allow update, delete: if false;
    }

    // ── password resets — server only, no client access ──────────────────────
    // SECURITY FIX — A04: Password reset tokens are managed server-side only.
    // No client should ever read or write this collection directly.
    match /password_resets/{id} {
      allow read, write: if false;
    }

    // ── refresh tokens — server only, no client access ───────────────────────
    // SECURITY FIX — A07: Refresh tokens are managed server-side only.
    match /refresh_tokens/{id} {
      allow read, write: if false;
    }

    // ── email verifications — server only ────────────────────────────────────
    match /email_verifications/{id} {
      allow read, write: if false;
    }

    // ── deny everything else ──────────────────────────────────────────────────
    // SECURITY FIX — A01: Explicit deny-all catch-all rule.
    // Any collection not explicitly listed above is inaccessible.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
